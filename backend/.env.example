# LLM
LLM_PROVIDER=mimo
LLM_API_KEY=
LLM_MODEL=mimo-v2-pro
LLM_BASE_URL=https://api.mimo-v2.com/v1
LLM_AUTH_HEADER=authorization
LLM_TIMEOUT_SECONDS=20

# Data
DATABASE_URL=postgresql://local_route:local_route@localhost:5432/local_route
POI_SQLITE_PATH=./data/processed/hefei_pois.sqlite
RAG_ENABLED=true
VECTOR_DB_PATH=./data/chroma
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT_SECONDS=30

# Map
AMAP_KEY=
AMAP_BASE_URL=https://restapi.amap.com
AMAP_TIMEOUT_SECONDS=5

# App
APP_PORT=8000
DEFAULT_CITY=shanghai
APP_STATE_SQLITE_PATH=./data/processed/app_state.sqlite
