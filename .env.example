# LLM
LLM_PROVIDER=longcat
LLM_API_KEY=
LLM_MODEL=LongCat-Flash-Chat
LLM_BASE_URL=https://api.longcat.chat/openai/v1
LLM_AUTH_HEADER=authorization
LLM_TIMEOUT_SECONDS=30

# Data
DATABASE_URL=postgresql://local_route:local_route@localhost:5432/local_route
VECTOR_DB_PATH=./data/chroma

# Map
AMAP_KEY=
AMAP_SECURITY_CODE=

# App
APP_PORT=8000
FRONTEND_PORT=5173
DEFAULT_CITY=shanghai
VITE_API_BASE_URL=/api
